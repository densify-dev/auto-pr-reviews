{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "default_agent": "build",
  "agent": {
    "bitbucket-pr-review": {
      "mode": "primary",
      "model": "opencode/big-pickle"
    },
    "github-pr-review": {
      "mode": "primary",
      "model": "opencode/big-pickle"
    }
  },
  "instructions": [],
  "share": "disabled",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "external_directory": {
    },
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "lsp": "allow",
    "todowrite": "allow",
    "question": "allow",
    "task": "allow",
    "doom_loop": "ask",
    "skill": "allow",
    "bash": {
      "*": "allow",
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GH_MCP_TOKEN}"
      }
    },
    "bitbucket": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "headers": {
        "Authorization": "Basic {env:BB_MCP_TOKEN}"
      }
    }
  }
}
